---
// ToDo component with handwritten notebook style
// Handle automatic task migration from tomorrow to today
import HomeIcon from "../icons/HomeIcon.astro";
import ClockIcon from "../icons/ClockIcon.astro";
import EmptyIcon from "../icons/EmptyIcon.astro";
import EmptyLargeIcon from "../icons/EmptyLargeIcon.astro";
---

<!-- Add new task form -->
<section aria-labelledby="add-task-heading" class="bg-white rounded-lg shadow-lg p-6 mb-8 border-2 border-amber-200 hover:border-amber-300 transition-all duration-300">
  <h2 id="add-task-heading" class="sr-only">Add New Task</h2>
  <form id="add-task-form" class="space-y-4" onsubmit="return false;">
    <div class="flex flex-col sm:flex-row gap-3">
      <label for="new-task" class="sr-only">Task description</label>
      <input 
        type="text" 
        id="new-task" 
        name="task-text"
        placeholder="What needs to be done?" 
        aria-label="Task description"
        aria-required="true"
        class="flex-1 px-4 py-3 border-2 border-amber-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent text-amber-900 handwritten placeholder:text-amber-400 transition-all duration-200"
      />
      <button 
        id="add-task-btn"
        type="submit"
        aria-label="Add task"
        class="bg-amber-600 hover:bg-amber-700 active:bg-amber-800 text-white px-8 py-3 rounded-lg font-bold transition-all duration-200 handwritten shadow-md hover:shadow-lg transform hover:-translate-y-0.5 active:translate-y-0 whitespace-nowrap sm:w-auto w-full"
      >
        Add Task
      </button>
    </div>
    
    <!-- Advanced options -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
      <!-- Date selection -->
      <fieldset class="flex gap-3">
        <legend class="sr-only">Select due date</legend>
        <label class="flex items-center gap-2 cursor-pointer group">
          <input 
            type="radio" 
            name="task-date" 
            value="today" 
            checked
            aria-label="Due today"
            class="w-4 h-4 text-amber-600 focus:ring-amber-500 focus:ring-2 cursor-pointer"
          />
          <span class="text-amber-900 handwritten group-hover:text-amber-700 transition-colors text-sm">Today</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer group">
          <input 
            type="radio" 
            name="task-date" 
            value="tomorrow" 
            aria-label="Due tomorrow"
            class="w-4 h-4 text-amber-600 focus:ring-amber-500 focus:ring-2 cursor-pointer"
          />
          <span class="text-amber-900 handwritten group-hover:text-amber-700 transition-colors text-sm">Tomorrow</span>
        </label>
      </fieldset>
      
      <!-- Priority selection -->
      <div>
        <label for="task-priority" class="sr-only">Priority</label>
        <select 
          id="task-priority" 
          name="task-priority"
          aria-label="Task priority"
          class="w-full px-3 py-2 border-2 border-amber-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 text-amber-900 handwritten text-sm"
        >
          <option value="none">No Priority</option>
          <option value="low">Low Priority</option>
          <option value="medium">Medium Priority</option>
          <option value="high">High Priority</option>
        </select>
      </div>
      
      <!-- Category selection -->
      <div>
        <label for="task-category" class="sr-only">Category</label>
        <select 
          id="task-category" 
          name="task-category"
          aria-label="Task category"
          class="w-full px-3 py-2 border-2 border-amber-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 text-amber-900 handwritten text-sm"
        >
          <option value="">No Category</option>
          <option value="work">Work</option>
          <option value="personal">Personal</option>
          <option value="shopping">Shopping</option>
          <option value="health">Health</option>
          <option value="other">Other</option>
        </select>
      </div>
    </div>
  </form>
</section>

<!-- Task Stats & Actions -->
<div class="bg-gradient-to-r from-amber-50 to-amber-100 rounded-lg p-4 mb-6 border border-amber-200">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <!-- Stats -->
    <div class="flex gap-6">
      <div class="text-center">
        <div id="total-tasks-count" class="text-2xl font-bold text-amber-900 handwritten">0</div>
        <div class="text-xs text-amber-700 handwritten">Total</div>
      </div>
      <div class="text-center">
        <div id="active-tasks-count" class="text-2xl font-bold text-amber-900 handwritten">0</div>
        <div class="text-xs text-amber-700 handwritten">Active</div>
      </div>
      <div class="text-center">
        <div id="completed-tasks-count" class="text-2xl font-bold text-green-700 handwritten">0</div>
        <div class="text-xs text-green-600 handwritten">Done</div>
      </div>
    </div>
    
    <!-- Search & Filter -->
    <div class="flex gap-2 flex-1 max-w-md">
      <input 
        type="search" 
        id="task-search" 
        placeholder="Search tasks..."
        aria-label="Search tasks"
        class="flex-1 px-3 py-2 border-2 border-amber-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 text-amber-900 handwritten text-sm"
      />
    </div>
    
    <!-- Actions -->
    <div class="flex gap-2">
      <button 
        id="undo-btn"
        type="button"
        aria-label="Undo last action"
        disabled
        class="action-icon-btn"
        title="Undo (Ctrl+Z)">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 7v6h6"></path>
          <path d="M21 17a9 9 0 00-9-9 9 9 0 00-6 2.3L3 13"></path>
        </svg>
      </button>
      <button 
        id="redo-btn"
        type="button"
        aria-label="Redo last action"
        disabled
        class="action-icon-btn"
        title="Redo (Ctrl+Y)">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 7v6h-6"></path>
          <path d="M3 17a9 9 0 019-9 9 9 0 016 2.3l3 2.7"></path>
        </svg>
      </button>
      <div class="w-px h-6 bg-amber-300"></div>
      <button 
        id="export-btn"
        type="button"
        aria-label="Export tasks"
        class="action-icon-btn"
        title="Export (Ctrl+E)">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
      </button>
      <button 
        id="import-btn"
        type="button"
        aria-label="Import tasks"
        class="action-icon-btn"
        title="Import (Ctrl+I)">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"></path>
          <polyline points="17 8 12 3 7 8"></polyline>
          <line x1="12" y1="3" x2="12" y2="15"></line>
        </svg>
      </button>
      <input type="file" id="import-file-input" accept=".json" class="hidden" />
    </div>
  </div>
</div>

<!-- Original Uiverse Notebook Style Tasks -->
<section aria-labelledby="tasks-heading" class="bg-white rounded-lg shadow-lg p-6 border-2 border-amber-200 mb-8 hover:shadow-xl transition-shadow duration-300">
  <div class="flex flex-wrap justify-between items-center mb-6 pb-4 border-b-2 border-amber-100 gap-3">
    <h2 id="tasks-heading" class="text-2xl font-bold text-amber-900 handwritten">Your Tasks</h2>
    <div class="flex flex-wrap gap-2">
      <button 
        id="filter-all-btn"
        type="button"
        class="filter-btn active text-xs px-3 py-1.5 rounded-md handwritten transition-colors"
        data-filter="all"
      >
        All
      </button>
      <button 
        id="filter-high-btn"
        type="button"
        class="filter-btn text-xs px-3 py-1.5 rounded-md handwritten transition-colors"
        data-filter="high"
      >
        High
      </button>
      <button 
        id="filter-medium-btn"
        type="button"
        class="filter-btn text-xs px-3 py-1.5 rounded-md handwritten transition-colors"
        data-filter="medium"
      >
        Medium
      </button>
      <button 
        id="filter-low-btn"
        type="button"
        class="filter-btn text-xs px-3 py-1.5 rounded-md handwritten transition-colors"
        data-filter="low"
      >
        Low
      </button>
      <div class="w-px h-6 bg-amber-200"></div>
      <button 
        id="toggle-reorder-btn"
        type="button"
        aria-label="Toggle reorder mode"
        aria-pressed="false"
        class="text-xs text-amber-600 hover:text-amber-800 handwritten transition-colors px-3 py-1.5 rounded-md hover:bg-amber-50"
      >
        Reorder
      </button>
    </div>
  </div>
  
  <!-- Task Tabs -->
  <div class="task-tabs mb-6">
    <button 
      id="active-tab"
      class="task-tab active"
      data-tab="active"
      type="button">
      Active
    </button>
    <button 
      id="completed-tab"
      class="task-tab"
      data-tab="completed"
      type="button">
      Completed
    </button>
    <div class="task-tab-indicator"></div>
  </div>
  
  <!-- Active Tasks View -->
  <div id="active-tasks-view" class="task-view active">
    <!-- Today's Tasks -->
    <div class="mb-8">
      <h3 id="today-tasks-heading" class="text-lg font-bold text-amber-900 handwritten mb-4 flex items-center gap-2">
        <HomeIcon width={20} height={20} class="text-amber-700" ariaHidden={true} />
        Today
      </h3>
      <ul 
        id="today-tasks-list" 
        class="space-y-2"
        role="list"
        aria-labelledby="today-tasks-heading"
        aria-live="polite"
        aria-relevant="additions removals"
      >
        <!-- Today's tasks will be loaded here -->
      </ul>
      <div id="today-empty-state" class="text-center py-8 text-amber-600 handwritten hidden" role="status" aria-live="polite">
        <EmptyIcon width={48} height={48} class="mx-auto mb-3 text-amber-500" ariaHidden={true} />
        <p class="text-base">No tasks for today</p>
      </div>
    </div>

    <!-- Tomorrow's Tasks -->
    <div class="mb-6">
      <h3 id="tomorrow-tasks-heading" class="text-lg font-bold text-amber-900 handwritten mb-4 flex items-center gap-2">
        <ClockIcon width={20} height={20} class="text-amber-700" ariaHidden={true} />
        Tomorrow
      </h3>
      <ul 
        id="tomorrow-tasks-list" 
        class="space-y-2"
        role="list"
        aria-labelledby="tomorrow-tasks-heading"
        aria-live="polite"
        aria-relevant="additions removals"
      >
        <!-- Tomorrow's tasks will be loaded here -->
      </ul>
      <div id="tomorrow-empty-state" class="text-center py-8 text-amber-600 handwritten hidden" role="status" aria-live="polite">
        <EmptyIcon width={48} height={48} class="mx-auto mb-3 text-amber-500" ariaHidden={true} />
        <p class="text-base">No tasks for tomorrow</p>
      </div>
    </div>

    <!-- Empty state for active tasks -->
    <div id="active-empty-state" class="text-center py-12 hidden" role="status" aria-live="polite">
      <EmptyLargeIcon width={96} height={96} class="mx-auto mb-6 text-amber-500" ariaHidden={true} />
      <p class="text-amber-700 text-xl handwritten">
        No active tasks. Add your first task above!
      </p>
    </div>
  </div>
  
  <!-- Completed Tasks View -->
  <div id="completed-tasks-view" class="task-view">
    <!-- Time period filter -->
    <div class="flex flex-wrap gap-2 mb-6">
      <span class="text-sm text-amber-900 handwritten font-semibold">Group by:</span>
      <button 
        id="filter-day-btn"
        type="button"
        class="time-filter-btn active"
        data-period="day">
        Day
      </button>
      <button 
        id="filter-week-btn"
        type="button"
        class="time-filter-btn"
        data-period="week">
        Week
      </button>
      <button 
        id="filter-month-btn"
        type="button"
        class="time-filter-btn"
        data-period="month">
        Month
      </button>
      <button 
        id="filter-year-btn"
        type="button"
        class="time-filter-btn"
        data-period="year">
        Year
      </button>
    </div>

    <!-- Completed tasks grouped by date -->
    <div id="completed-tasks-grouped">
      <!-- Will be populated by JavaScript -->
    </div>
    
    <!-- Empty state for completed tasks -->
    <div id="completed-empty-state" class="text-center py-12 hidden" role="status" aria-live="polite">
      <EmptyLargeIcon width={96} height={96} class="mx-auto mb-6 text-amber-500" ariaHidden={true} />
      <p class="text-amber-700 text-xl handwritten">
        No completed tasks yet. Complete a task to see it here!
      </p>
    </div>
  </div>

  <!-- SVG filter for handwritten effect - Original Uiverse -->
  <svg height="0" width="0" aria-hidden="true">
    <filter id="handDrawnNoiseUiverse">
      <feTurbulence result="noise" numOctaves="8" baseFrequency="0.1" type="fractalNoise"></feTurbulence>
      <feDisplacementMap yChannelSelector="G" xChannelSelector="R" scale="3" in2="noise" in="SourceGraphic"></feDisplacementMap>
    </filter>
  </svg>
</section>

<!-- Edit Task Modal -->
<div id="edit-task-modal" class="modal-overlay hidden" role="dialog" aria-labelledby="edit-task-title" aria-modal="true">
  <div class="modal">
    <div class="flex justify-between items-center mb-4">
      <h3 id="edit-task-title" class="text-xl font-bold text-amber-900 handwritten">Edit Task</h3>
      <button id="close-edit-modal" type="button" aria-label="Close" class="text-amber-600 hover:text-amber-800 text-2xl leading-none">&times;</button>
    </div>
    
    <form id="edit-task-form" class="space-y-4">
      <div>
        <label for="edit-task-text" class="block text-sm font-medium text-amber-900 handwritten mb-1">Task</label>
        <input 
          type="text" 
          id="edit-task-text" 
          class="w-full px-4 py-2 border-2 border-amber-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 text-amber-900 handwritten"
          required
        />
      </div>
      
      <div>
        <label for="edit-task-priority" class="block text-sm font-medium text-amber-900 handwritten mb-1">Priority</label>
        <select 
          id="edit-task-priority" 
          class="w-full px-4 py-2 border-2 border-amber-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 text-amber-900 handwritten"
        >
          <option value="none">No Priority</option>
          <option value="low">Low Priority</option>
          <option value="medium">Medium Priority</option>
          <option value="high">High Priority</option>
        </select>
      </div>
      
      <div>
        <label for="edit-task-category" class="block text-sm font-medium text-amber-900 handwritten mb-1">Category</label>
        <select 
          id="edit-task-category" 
          class="w-full px-4 py-2 border-2 border-amber-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 text-amber-900 handwritten"
        >
          <option value="">No Category</option>
          <option value="work">Work</option>
          <option value="personal">Personal</option>
          <option value="shopping">Shopping</option>
          <option value="health">Health</option>
          <option value="other">Other</option>
        </select>
      </div>
      
      <div class="flex gap-3 pt-2">
        <button 
          type="submit" 
          class="flex-1 bg-amber-600 hover:bg-amber-700 text-white px-6 py-2 rounded-lg font-bold handwritten transition-colors"
        >
          Save Changes
        </button>
        <button 
          type="button" 
          id="cancel-edit-btn"
          class="flex-1 bg-gray-300 hover:bg-gray-400 text-gray-800 px-6 py-2 rounded-lg font-bold handwritten transition-colors"
        >
          Cancel
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Overdue Tasks Alert Modal -->
<div id="overdue-alert-modal" class="modal-overlay hidden" role="dialog" aria-labelledby="overdue-alert-title" aria-modal="true">
  <div class="modal max-w-lg">
    <div class="flex items-start gap-3 mb-4">
      <div class="flex-shrink-0 w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="12"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
      </div>
      <div class="flex-1">
        <h3 id="overdue-alert-title" class="text-xl font-bold text-amber-900 handwritten mb-2">Incomplete Tasks</h3>
        <p class="text-amber-700 handwritten text-sm">These tasks from yesterday weren't completed and have been moved to tomorrow:</p>
      </div>
    </div>
    
    <div id="overdue-tasks-list" class="bg-amber-50 rounded-lg p-4 mb-4 max-h-64 overflow-y-auto">
      <!-- Overdue tasks will be listed here -->
    </div>
    
    <button 
      id="close-overdue-alert"
      type="button"
      class="w-full bg-amber-600 hover:bg-amber-700 text-white px-6 py-3 rounded-lg font-bold handwritten transition-colors"
    >
      Got it!
    </button>
  </div>
</div>