---
// Footer component for to-do list website
---

<footer class="bg-amber-25 border-t border-amber-200 mt-auto">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
      <div class="footer-brand">
        <div class="flex items-center mb-3">
          <span class="bg-amber-600 text-cream w-7 h-7 rounded-md flex items-center justify-center mr-2 font-bold text-sm handwritten">✓</span>
          <span class="font-bold text-xl text-amber-900 handwritten">TodoList</span>
        </div>
        <p class="text-amber-700 leading-relaxed m-0 handwritten">
          Stay organized and productive with our simple to-do list app.
        </p>
      </div>
      
      <div class="flex gap-12 md:gap-8">
        <div class="link-group">
          <h4 class="text-amber-900 font-bold mb-3 text-sm uppercase tracking-wide handwritten">Features</h4>
          <a href="/tasks" class="block text-amber-700 no-underline mb-2 hover:text-amber-900 transition-colors handwritten">Task Management</a>
          <a href="/completed" class="block text-amber-700 no-underline mb-2 hover:text-amber-900 transition-colors handwritten">Progress Tracking</a>
          <a href="/categories" class="block text-amber-700 no-underline mb-2 hover:text-amber-900 transition-colors handwritten">Categories</a>
        </div>
        
        <div class="link-group">
          <h4 class="text-amber-900 font-bold mb-3 text-sm uppercase tracking-wide handwritten">Support</h4>
          <a href="/help" class="block text-amber-700 no-underline mb-2 hover:text-amber-900 transition-colors handwritten">Help Center</a>
          <a href="/contact" class="block text-amber-700 no-underline mb-2 hover:text-amber-900 transition-colors handwritten">Contact Us</a>
          <a href="/feedback" class="block text-amber-700 no-underline mb-2 hover:text-amber-900 transition-colors handwritten">Feedback</a>
        </div>
      </div>
    </div>
    
    <div class="pt-6 border-t border-amber-200 text-center">
      <p class="text-amber-700 text-sm m-0 handwritten">&copy; 2026 TodoList. Built with Astro.</p>
    </div>
  </div>
</footer>