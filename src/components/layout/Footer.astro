---
// Footer component for to-do list website
import CheckIcon from '../icons/CheckIcon.astro';
---

<footer class="bg-gradient-to-b from-amber-50 to-amber-100 border-t-2 border-amber-200 mt-auto relative z-10">
  <div class="max-w-6xl mx-auto px-6 py-12 bg-gradient-to-b from-amber-50 to-amber-100">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-10">
      <!-- Brand Section -->
      <div class="footer-brand">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-10 h-10 bg-gradient-to-br from-amber-600 to-amber-700 rounded-xl flex items-center justify-center shadow-md">
            <CheckIcon width={20} height={20} class="text-white" ariaHidden={true} />
          </span>
          <h2 class="font-bold text-2xl text-amber-900 handwritten m-0">TodoList</h2>
        </div>
        <p class="text-amber-800 leading-relaxed mb-4 handwritten text-sm">
          Stay organized and productive with our simple, beautiful to-do list app. Track tasks, set priorities, and achieve your goals.
        </p>
        <!-- Social Links -->
        <div class="flex gap-3">
          <a href="#" aria-label="Twitter" class="social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"></path>
            </svg>
          </a>
          <a href="#" aria-label="GitHub" class="social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"></path>
            </svg>
          </a>
          <a href="#" aria-label="LinkedIn" class="social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
            </svg>
          </a>
        </div>
      </div>
      
      <!-- Quick Links -->
      <div class="grid grid-cols-2 gap-8">
        <div class="link-group">
          <h3 class="text-amber-900 font-bold mb-4 text-sm uppercase tracking-wide handwritten flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
              <path d="M2 17l10 5 10-5M2 12l10 5 10-5"></path>
            </svg>
            Features
          </h3>
          <nav aria-label="Features navigation" class="space-y-2">
            <a href="/tasks" class="footer-link">Task Management</a>
            <a href="#tasks" class="footer-link">Priorities</a>
            <a href="#tasks" class="footer-link">Categories</a>
            <a href="#tasks" class="footer-link">Search & Filter</a>
          </nav>
        </div>
        
        <div class="link-group">
          <h3 class="text-amber-900 font-bold mb-4 text-sm uppercase tracking-wide handwritten flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
              <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
            Support
          </h3>
          <nav aria-label="Support navigation" class="space-y-2">
            <a href="/help" class="footer-link">Help Center</a>
            <a href="/contact" class="footer-link">Contact Us</a>
            <a href="/feedback" class="footer-link">Feedback</a>
            <a href="/faq" class="footer-link">FAQ</a>
          </nav>
        </div>
      </div>
      
      <!-- Bug Report -->
      <div>
        <h3 class="text-amber-900 font-bold mb-4 text-sm uppercase tracking-wide handwritten flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 9v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          Report a Bug
        </h3>
        <p class="text-amber-800 text-sm mb-3 handwritten">Found an issue? Let us know!</p>
        <a 
          href="mailto:krisjohn.rodriguez@gmail.com?subject=TodoList Bug Report&body=Please describe the bug you encountered:"
          class="inline-flex items-center gap-2 px-4 py-2 bg-amber-600 hover:bg-amber-700 text-white rounded-lg font-bold handwritten text-sm transition-colors"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
          Email Bug Report
        </a>
        <p class="text-amber-700 text-xs mt-2 handwritten">krisjohn.rodriguez@gmail.com</p>
      </div>
    </div>
    
    <!-- Bottom Bar -->
    <div class="pt-8 border-t-2 border-amber-200 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-amber-800 text-sm m-0 handwritten">
        &copy; 2026 TodoList. Built with 
        <a href="https://astro.build" target="_blank" rel="noopener" class="text-amber-600 hover:text-amber-700 font-bold">Astro</a>
      </p>
      <div class="flex gap-6">
        <a href="/privacy" class="text-amber-800 hover:text-amber-600 text-sm handwritten transition-colors">Privacy</a>
        <a href="/terms" class="text-amber-800 hover:text-amber-600 text-sm handwritten transition-colors">Terms</a>
        <a href="/cookies" class="text-amber-800 hover:text-amber-600 text-sm handwritten transition-colors">Cookies</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: rgba(217, 119, 6, 0.1);
    border: 2px solid rgba(217, 119, 6, 0.2);
    border-radius: 0.5rem;
    color: #92400e;
    transition: all 0.2s ease;
  }
  
  .social-link:hover {
    background: #d97706;
    border-color: #d97706;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(217, 119, 6, 0.3);
  }
  
  .footer-link {
    display: block;
    color: #92400e;
    font-family: 'Kalam', cursive;
    font-size: 0.875rem;
    transition: all 0.2s ease;
    position: relative;
    padding-left: 1rem;
  }
  
  .footer-link::before {
    content: '→';
    position: absolute;
    left: 0;
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.2s ease;
  }
  
  .footer-link:hover {
    color: #d97706;
    padding-left: 1.25rem;
  }
  
  .footer-link:hover::before {
    opacity: 1;
    transform: translateX(0);
  }
</style>