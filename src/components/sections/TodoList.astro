---
// Todo List section with handwritten notebook style
import ToDo from "../layout/ToDo.astro";
import CheckIcon from "../icons/CheckIcon.astro";
---

<section class="relative overflow-hidden py-16 px-4" id="tasks">
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-20 right-20 w-80 h-80 bg-amber-300 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 left-10 w-96 h-96 bg-amber-200 rounded-full blur-3xl"></div>
  </div>
  
  <div class="max-w-4xl mx-auto relative z-10">
    <div class="text-center mb-12">
      <div class="inline-block mb-4">
        <span class="inline-flex items-center gap-2 bg-amber-600 text-white px-4 py-2 rounded-full text-sm font-bold handwritten">
          <CheckIcon width={16} height={16} />
          manage tasks
        </span>
      </div>
      
      <h2 class="font-bold text-amber-900 mb-4 handwritten">
        Your Tasks
      </h2>
      <p class="text-amber-700 text-lg handwritten font-light">
        Add, organize, and complete your daily tasks with ease
      </p>
    </div>

    <!-- ToDo Component -->
    <ToDo />
  </div>
</section>

<script>
  import '/src/script/supabase-sync.js';
  import '/src/script/script.js';
  import '/src/script/subtasks.js';
  import '/src/script/completed-grouping.js';
  
  // Initialize Supabase sync after page load
  document.addEventListener('DOMContentLoaded', async () => {
    if ((window as any).supabaseSync) {
      await (window as any).supabaseSync.initializeSync();
    }
  });
</script>



