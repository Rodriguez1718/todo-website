---
// Todo List section with handwritten notebook style
import ToDo from "../layout/ToDo.astro";
import Notes from "../layout/Notes.astro";
---

<section class="bg-amber-50 py-16 px-4" id="tasks">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-4xl font-bold text-amber-900 mb-4 handwritten">
        Your Tasks
      </h2>
      <p class="text-amber-700 text-lg handwritten">
        Add, organize, and complete your daily tasks
      </p>
    </div>

    <!-- ToDo Component -->
    <ToDo />

    <!-- Notes Component -->
    <Notes />
  </div>

  <!-- SVG filter for handwritten effect -->
  <svg height="0" width="0">
    <filter id="handDrawnNoise">
      <feTurbulence result="noise" numOctaves="8" baseFrequency="0.1" type="fractalNoise"></feTurbulence>
      <feDisplacementMap yChannelSelector="G" xChannelSelector="R" scale="3" in2="noise" in="SourceGraphic"></feDisplacementMap>
    </filter>
  </svg>
</section>

<script>
  import '/src/script/script.js';
</script>



