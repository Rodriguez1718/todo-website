---
/**
 * Empty State Icon Component
 */
interface Props {
  width?: number;
  height?: number;
  class?: string;
  ariaHidden?: boolean;
}

const {
  width = 40,
  height = 40,
  class: className = '',
  ariaHidden = true,
} = Astro.props;
---

<svg
  {width}
  {height}
  viewBox="0 0 100 100"
  fill="none"
  class={`sketchy-empty ${className}`}
  aria-hidden={ariaHidden}
  xmlns="http://www.w3.org/2000/svg"
>
  <circle cx="50" cy="50" r="30" stroke="currentColor" stroke-width="3" fill="none" stroke-dasharray="2,3"/>
  <path d="M35 45 L45 55 L65 35" stroke="currentColor" stroke-width="3" stroke-linecap="round" fill="none" opacity="0.3"/>
</svg>
