---
/**
 * Clock Icon Component (for Tomorrow)
 */
interface Props {
  width?: number;
  height?: number;
  class?: string;
  ariaHidden?: boolean;
}

const {
  width = 24,
  height = 24,
  class: className = '',
  ariaHidden = true,
} = Astro.props;
---

<svg
  {width}
  {height}
  viewBox="0 0 24 24"
  fill="none"
  class={`sketchy-icon ${className}`}
  aria-hidden={ariaHidden}
  xmlns="http://www.w3.org/2000/svg"
>
  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
  <polyline points="12,6 12,12 16,14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
